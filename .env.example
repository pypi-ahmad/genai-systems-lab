# Runtime credentials are BYOK-only. Provide the API key via the X-API-Key
# request header for HTTP calls.
APP_ENV=dev
# Required for persistent auth sessions. Must be >= 16 characters.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# If unset in dev, an ephemeral per-process secret is used (tokens lost on restart).
GENAI_SYSTEMS_LAB_JWT_SECRET=
GENAI_SYSTEMS_LAB_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GENAI_SYSTEMS_LAB_ENABLE_PUBLIC_SIGNUP=true
GENAI_SYSTEMS_LAB_DATABASE_URL=
GENAI_SYSTEMS_LAB_AUTH_COOKIE_SAMESITE=lax
OTEL_ENABLED=false
OTEL_CONSOLE_EXPORT=false
OTEL_SERVICE_NAME=genai-systems-lab
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
MODEL_DEFAULT_DEV=gemini-3-flash-preview
MODEL_DEFAULT_PROD=gemini-3.1-pro-preview
PROJECT_MODELS_JSON={}