# ── LLM ──────────────────────────────────────────────
# Runtime credentials are BYOK-only. Provide the API key via the X-API-Key
# request header when calling the API.
MODEL_FAST=gemini-3-flash-preview
MODEL_PRO=gemini-3.1-pro-preview
TEMPERATURE=0.0

# ── Execution sandbox ────────────────────────────────
CODE_EXECUTION_TIMEOUT_SECONDS=30
MAX_RETRIES=3

# ── Storage ──────────────────────────────────────────
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
MAX_UPLOAD_SIZE_MB=100

# ── API ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Logging ──────────────────────────────────────────
LOG_LEVEL=INFO
